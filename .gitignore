# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain confidential information, so it\'s best to ignore them.
# https://docs.unity3d.com
[Mm]emoryCaptures/

# Asset store tools versioning cache
.unity3dstore/

# Autogenerated VS/Mac/Rider solution and project files
ExportedObj/
.consulo/
.idea/
.vs/
[Dd]ata/[Ss]erialize[Rr]untime[Uu]nity[Ee]ditor.[Aa]ssembly/[Cc]hildren/
[Dd]ata/[Ss]erialize[Rr]untime[Uu]nity[Ee]ditor.[Aa]ssembly/[Ff]iles/
.jdi/
.luacheckrc
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.vcinfo
*.booproj
*.pidb
*.data
*.sbs
*.sbstemp
*.opendb
*.VC.db

# Unity-generated text files
*.log
*.pdata
# build log files should also be ignored
/[Mm]aster/[Bb]uilds/
/[Ss]napshots/

# Unity-generated internal meta files
sysinfo.txt

# Unity-generated asset meta file for the built application.
# It should be ignored to avoid conflicts, as it\'s generated during the build process
# and is not a source file.
*.buildinfo

# Unity-generated text file for the built application.
# It should be ignored to avoid conflicts, as it\'s generated during the build process
# and is not a source file.
*.manifest

# Backups of blend files generated by Unity
*.blend[0-9]

# Depending on your Unity version, Studio project files might be generated
[Ss]tudio001/
[Ss]tudio002/

# Local data generated by the Unity Package Manager
[Pp]ackages/[Mm]anifest.json.lock
[Pp]ackages/[Oo]verride.txt

# Visual Studio cache directory
.sonarlint/

# Gradle files
.gradle/

# Yarn lock files
yarn.lock
